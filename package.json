{
    "name": "@pookiesoft/bongbot-quote",
    "version": "0.1.0",
    "description": "BongBot QuoteDB command module",
    "main": "./dist/index.js",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "!dist/standalone.*"
    ],
    "publishConfig": {
        "registry": "https://npm.pkg.github.com"
    },
    "scripts": {
        "build": "bun build --target bun --outdir dist --minify --sourcemap src/standalone.ts",
        "build:lib": "node esbuild.config.mjs --lib && npx tsc --emitDeclarationOnly",
        "prepublishOnly": "npm run build:lib",
        "build-dev": "docker build --secret id=NODE_AUTH_TOKEN,env=NODE_AUTH_TOKEN -t bongbot-quote . && docker run --rm --env-file .env --volume ./logs:/app/logs bongbot-quote",
        "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --json --coverage --outputFile=report.json --passWithNoTests --silent"
    },
    "peerDependencies": {
        "discord.js": "^14.26.3"
    },
    "devDependencies": {
        "@pookiesoft/bongbot-core": "^1.6.1",
        "@types/jest": "^30.0.0",
        "better-sqlite3": "^12.9.0",
        "cross-env": "^10.1.0",
        "discord.js": "^14.26.3",
        "esbuild": "^0.28.0",
        "jest": "^30.2.0",
        "jest-junit": "^17.0.0",
        "msw": "^2.13.6",
        "ts-jest": "^29.4.6",
        "ts-jest-resolver": "^2.0.1",
        "ts-node": "^10.9.2",
        "typescript": "^6.0.3"
    }
}
